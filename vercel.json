{
    "version": 2,
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/.well-known/discord",
            "dest": "/.well-known/discord",
            "headers": {
                "Content-Type": "text/plain"
            }
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "docs.adan.sh"
                }
            ],
            "dest": "/pages/docs/index.html"
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "host",
                    "value": "install.adan.sh"
                }
            ],
            "dest": "/pages/install/index.html"
        },
        {
            "handle": "filesystem"
        }
    ]
}